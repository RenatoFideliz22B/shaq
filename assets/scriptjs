/* detectar sintomas */

function detectarSintomas(texto){

texto = texto.toLowerCase();

for(let chave in sintomasBanco){

for(let palavra of sintomasBanco[chave]){

if(texto.includes(palavra)){

if(!sintomasUsuario.includes(chave)){
sintomasUsuario.push(chave);
}

}

}

}

}

/* analisar saúde */

function analisarSaude(){

let resultados = [];

for(let d of diagnosticos){

let score = 0;

for(let s of d.sintomas){

if(sintomasUsuario.includes(s)){
score++;
}

}

let compatibilidade = score / d.sintomas.length;

if(compatibilidade >= 0.25){

resultados.push({
nome:d.nome,
recomendacao:d.recomendacao,
compatibilidade:compatibilidade
});

}

}

resultados.sort((a,b)=> b.compatibilidade - a.compatibilidade);

return resultados.slice(0,4);

}

/* urgência */

function nivelUrgencia(){

if(sintomasUsuario.includes("faltaAr")){
return "🚨 Possível sintoma grave. Procure atendimento médico.";
}

if(sintomasUsuario.includes("febre")){
return "⚠️ Febre detectada. Monitorar temperatura.";
}

return "🟢 Sintomas parecem leves no momento.";

}

/* perguntas da IA */

const perguntasIA = [

"Há quanto tempo você está com esses sintomas?",
"Você sente cansaço também?",
"Você mediu sua temperatura?",
"Está com dor de cabeça também?",
"Os sintomas estão piorando?"

];

/* gerar resposta */

function gerarResposta(pergunta){

memoria.push(pergunta);

detectarSintomas(pergunta);

if(sintomasUsuario.length === 0){

return "Não consegui identificar sintomas específicos.\n\nPode explicar melhor o que está sentindo?";

}

let resposta = "🔎 Sintomas identificados:\n";

let lista = sintomasUsuario.map(s => nomesSintomas[s]);

resposta += lista.join(", ");

let analises = analisarSaude();

if(analises.length > 0){

resposta += "\n\n🧬 Possíveis condições:\n";

analises.forEach(a=>{

let porcentagem = Math.round(a.compatibilidade * 100);

let recomendacao = a.recomendacao[
Math.floor(Math.random()*a.recomendacao.length)
];

resposta += "\n• " + a.nome + " (" + porcentagem + "% compatível)";
resposta += "\n🩺 " + recomendacao + "\n";

});

}

let perguntaExtra = perguntasIA[Math.floor(Math.random()*perguntasIA.length)];

resposta += "\n💬 " + perguntaExtra;

resposta += "\n\n" + nivelUrgencia();

resposta += "\n\n⚠️ Esta IA fornece apenas informações educativas e não substitui um médico.";

return resposta;

}

/* responder */

function responder(){

let pergunta = input.value.trim();

if(pergunta === "") return;

criarMensagem(pergunta,"usuario");

input.value="";

setTimeout(()=>{

let resposta = gerarResposta(pergunta);

criarMensagem(resposta,"ia");

},800);

}

/* enviar com ENTER */

input.addEventListener("keypress",function(e){

if(e.key === "Enter"){
responder();
}

});